[Unit]
Description=Noise Archaeologist Backend
After=network.target

[Service]
Type=simple
User=anfield
WorkingDirectory=/home/anfield/project/game-demo
EnvironmentFile=/etc/noise-archaeologist/backend.env
ExecStart=/home/anfield/project/game-demo/.venv/bin/uvicorn app.main:app --app-dir backend --host 127.0.0.1 --port 8000 --workers 4
Restart=always
RestartSec=3

[Install]
WantedBy=multi-user.target
